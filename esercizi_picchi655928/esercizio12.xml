<?xml version="1.0" encoding="UTF-8"?>
<!--
    Filename: lettera_bellini_facsimile.xml
    Author: Elisabetta Picchi
    Date: 07/06/2026
    Descrizione: Codifica TEI image-based della lettera Bellini con tagset facsimile
    e collegamento testo-immagine.
-->
<TEI xmlns="http://www.tei-c.org/ns/1.0">
    <teiHeader>
        <fileDesc>
            <titleStmt>
                <title>Lettera Bellini: edizione image-based</title>
                <respStmt>
                    <resp>Trascrizione e codifica XML-TEI a cura di</resp>
                    <name>Elisabetta Picchi</name>
                </respStmt>
            </titleStmt>
            <publicationStmt>
                <publisher>Università di Pisa - Corso di Codifica di Testi</publisher>
                <date when="2026">2026</date>
            </publicationStmt>
            <sourceDesc>
                <p>
                    Lettera attribuita a Bellini, codificata a partire dall'immagine fornita
                    per l'esercizio sulle edizioni image-based.
                </p>
            </sourceDesc>
        </fileDesc>
    </teiHeader>

    <facsimile>
        <surface xml:id="lettera_bellini">
            <graphic url="lettera_bellini.png" width="1306" height="884"/>
            <zone ulx="20" uly="28" lrx="638" lry="145" rendition="" xml:id="verde"/>
            <zone ulx="25" uly="152" lrx="638" lry="504" rendition="" xml:id="celeste"/>
            <zone ulx="26" uly="514" lrx="639" lry="869" rendition="" xml:id="blu"/>
            <zone ulx="649" uly="22" lrx="1285" lry="116" rendition="" xml:id="rosso"/>
            <zone ulx="700" uly="125" lrx="1272" lry="838" rendition="" xml:id="arancio"/>
            <zone ulx="984" uly="786" lrx="1272" lry="859" rendition="" xml:id="fucsia"/>
        </surface>
    </facsimile>

    <text>
        <body>
            <div type="letter" facs="#z_verso_destra">
                <opener>
                    <dateline facs="#z_l1">
                        <lb n="1" facs="#z_l1"/>
                        <date when="1835-01-08">8 Gennaio 1835</date>
                    </dateline>
                    <salute facs="#z_l2">
                        <lb n="2" facs="#z_l2"/>
                        <unclear>Cara</unclear>
                        <rs type="person">sorella</rs>
                    </salute>
                </opener>

                <p>
                    <lb n="3" facs="#z_l3"/>
                    <unclear>Quando</unclear>
                    <unclear>fosti</unclear>
                    <unclear>così</unclear>
                    <unclear>mia</unclear>

                    <lb n="4" facs="#z_l4"/>
                    <unclear>a me</unclear>
                    <gap reason="illegible" quantity="3" unit="words"/>
                    <unclear>non</unclear>

                    <lb n="5" facs="#z_l5"/>
                    <unclear>operar</unclear>
                    <unclear>che</unclear>
                    <unclear>un</unclear>

                    <lb n="6" facs="#z_l6"/>
                    <unclear>immenso</unclear>
                    <unclear>servizio</unclear>
                    <unclear>a</unclear>

                    <lb n="7" facs="#z_l7"/>
                    <unclear>codesto</unclear>
                    <unclear>e</unclear>
                    <unclear>non</unclear>
                    <unclear>sapendo</unclear>

                    <lb n="8" facs="#z_l8"/>
                    <unclear>mai</unclear>
                    <unclear>ringraziare</unclear>
                    <unclear>la</unclear>

                    <lb n="9" facs="#z_l9"/>
                    <unclear>buona</unclear>
                    <unclear>e</unclear>
                    <unclear>...</unclear>

                    <lb n="10" facs="#z_l10"/>
                    <unclear>nostra</unclear>
                    <unclear>povera</unclear>
                    <unclear>figlia</unclear>

                    <lb n="11" facs="#z_l11"/>
                    <unclear>così</unclear>
                    <unclear>...</unclear>
                </p>

                <closer>
                    <signed>
                        <gap reason="illegible" quantity="1" unit="word"/>
                    </signed>
                </closer>
            </div>

            <div type="address" facs="#z_recto_sinistra">
                <head>Indirizzo e segni postali</head>

                <p facs="#z_addr_1">
                    <lb n="a1" facs="#z_addr_1"/>
                    <gap reason="illegible" quantity="1" unit="line"/>
                </p>

                <p facs="#z_addr_2">
                    <lb n="a2" facs="#z_addr_2"/>
                    <gap reason="illegible" quantity="1" unit="line"/>
                </p>

                <stamp facs="#z_stamp_1" type="postmark">
                    <p>
                        <gap reason="illegible" quantity="1" unit="stamp"/>
                    </p>
                </stamp>

                <p facs="#z_rotated_text" rend="rotated">
                    <lb n="a3" facs="#z_rotated_text"/>
                    <gap reason="illegible" quantity="1" unit="line"/>
                </p>
            </div>

            <div type="editorialNote">
                <head>Nota alla trascrizione</head>
                <p>
                    La trascrizione è conservativa: le parole non leggibili con sicurezza sono marcate con
                    <gi>unclear</gi>, mentre le porzioni completamente illeggibili sono marcate con
                    <gi>gap</gi>. Il collegamento testo-immagine è realizzato con l'attributo
                    <att>facs</att> su <gi>div</gi>, <gi>p</gi>, <gi>dateline</gi>, <gi>salute</gi>
                    e <gi>lb</gi>, che puntano alle rispettive <gi>zone</gi> del facsimile.
                </p>
            </div>
        </body>
    </text>
</TEI>
