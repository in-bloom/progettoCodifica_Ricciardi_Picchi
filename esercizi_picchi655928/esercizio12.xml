    Descrizione: Codifica TEI image-based della lettera Bellini con tagset facsimile
    e collegamento testo-immagine.
-->
<TEI xmlns="http://www.tei-c.org/ns/1.0">
    <teiHeader>
        <fileDesc>
            <titleStmt>
                <title>Lettera Bellini: edizione image-based</title>
                <respStmt>
                    <resp>Trascrizione e codifica XML-TEI P5 a cura di</resp>
                    <persName xml:id="Elisabetta_Picchi">
                        <name>Elisabetta</name>
                        <surname>Picchi</surname>
                    </persName>
                </respStmt>
            </titleStmt>
            <publicationStmt>
                <publisher>Università di Pisa - Corso di Codifica di Testi</publisher>
                <date when="2026">2026</date>
            </publicationStmt>
            <sourceDesc>
                <p>
                    Lettera attribuita a Bellini, compositore del '800
                </p>
            </sourceDesc>
        </fileDesc>
    </teiHeader>

    <facsimile>
        <surface xml:id="lettera_bellini">

            <graphic url="lettera_bellini.png" width="1306" height="884"/>
            <zone ulx="21" uly="28" lrx="638" lry="146" rendition="" xml:id="verde"/>
            <zone ulx="26" uly="514" lrx="639" lry="870" rendition="" xml:id="azzurro"/>
            <zone ulx="24" uly="152" lrx="638" lry="505" rendition="" xml:id="celeste"/>
            <zone ulx="649" uly="22" lrx="1285" lry="116" rendition="" xml:id="rosso"/>
            <zone ulx="984" uly="786" lrx="1272" lry="859" rendition="" xml:id="rosa"/>
            <zone ulx="700" uly="125" lrx="1272" lry="838" rendition="" xml:id="arancione"/>

        </surface>
    </facsimile>

    <text>
        <body>

            <div type="letter" xml:id="lettera" facs="#lettera_bellini">

                <div type="mark" facs="#verde">
                <p>
                    <stamp type="postmark">
                    <desc>Timbro postale nella parte superiore sinistra</desc>
                    </stamp>
                </p>
                </div>

                <div type="address" facs="#celeste">
                <address>
                    <addrLine>
                    <persName>
                        <unclear>Monsieur</unclear>
                    </persName>
                    </addrLine>

                    <addrLine>
                    <unclear>Monsieur <gap reason="illegible"></gap>Pepoli</unclear>
                    </addrLine>

                    <addrLine>
                    <placeName>à Paris</placeName>
                    </addrLine>
                </address>

                <stamp type="postmark">
                    <desc>Timbro circolare</desc>
                </stamp>
                </div>

                <div type="mark" facs="#azzurro">
                <p>
                    <stamp type="postmark">
                    <desc>Timbro postale nella parte inferiore sinistra</desc>
                    </stamp>
                </p>

                <p>
                    <gap reason="illegible" extent="unknown"/>
                </p>
                </div>

                <div type="opener" facs="#rosso">
                <opener>
                    <dateline>
                    <date when="26"><unclear>Juin</unclear> 26:</date>
                    <placeName>Puteau</placeName>
                    </dateline>
                </opener>
                </div>

                <div type="message" facs="#arancione">
                <p>
                    <unclear>Mio caro <gap reason="illegible"></gap></unclear>
                    <s>Avendo steso l'intero duetto</s>
                    <s>e mancando in <gap reason="illegible"></gap> qualche</s>
                    <s>cosetta, desidererei che tu</s>
                    <s>t'incomodassi a venire a'</s>
                    <s>Puteau per tutto finire, e</s>
                    <s>nell'intero tempo darmi la</s>
                    <s>sortita di <gap reason="illegible"></gap>, se è termi-</s>
                    <s>nata. T'aspetto in qual giorno</s>
                    <s>ed in qual'ora sappi. - Addio</s>
                </p>

                </div>

                <div type="closer" facs="#rosa">
                <closer>
                    <signed>
                    <persName>
                        <unclear><gap reason="illegible"></gap> Bellini</unclear>
                    </persName>
                    </signed>
                </closer>
                </div>

            </div>

        </body>
    </text>
</TEI>
